{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LEARCredentialMachine V2 (jwt_vc_json)",

  "credential_configuration_id": "LEARCredentialMachine",
  "credential_format": "jwt_vc_json",
  "scope": "lear_credential_machine",
  "credential_definition": {
    "context": [
      "https://www.w3.org/ns/credentials/v2",
      "https://credentials.eudistack.eu/.well-known/credentials/lear_credential_machine/w3c/v2"
    ],
    "type": ["VerifiableCredential", "LEARCredentialMachine"]
  },
  "cryptographic_binding_methods_supported": ["did:key"],
  "credential_signing_alg_values_supported": ["ES256"],
  "proof_types_supported": {
    "jwt": { "proof_signing_alg_values_supported": ["ES256"] }
  },
  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Machine",
        "locale": "en",
        "description": "Verifiable Credential for machines"
      }
    ],
    "claims": [
      { "path": ["credentialSubject", "mandate", "mandatee", "domain"],    "display": [{ "name": "Domain",     "locale": "en" }] },
      { "path": ["credentialSubject", "mandate", "mandatee", "ipAddress"], "display": [{ "name": "IP Address", "locale": "en" }] },
      { "path": ["credentialSubject", "mandate", "mandator", "organizationIdentifier"], "display": [{ "name": "Organization", "locale": "en" }] },
      { "path": ["credentialSubject", "mandate", "power"], "display": [{ "name": "Powers", "locale": "en" }] }
    ]
  },
  "validity_days": 365,
  "issuer_type": "DETAILED",
  "cnf_required": true,
  "description": "Verifiable Credential for machines",
  "subject_extraction": {
    "strategy": "field",
    "fields": ["mandate.mandatee.domain"],
    "separator": null
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandate.mandator.organizationIdentifier"
  },

  "type": "object",
  "required": ["@context", "type", "issuer", "credentialSubject"],
  "additionalProperties": true,
  "properties": {
    "@context": { "type": "array", "items": { "type": "string" } },
    "id": { "type": "string" },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "LEARCredentialMachine" }
    },
    "issuer": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": { "id": { "type": "string" } }
    },
    "credentialSubject": {
      "type": "object",
      "required": ["mandate"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "mandate": {
          "type": "object",
          "required": ["mandatee", "mandator", "power"],
          "additionalProperties": true,
          "properties": {
            "mandatee": {
              "type": "object",
              "required": ["id"],
              "additionalProperties": true,
              "properties": {
                "id":        { "type": "string" },
                "domain":    { "type": "string" },
                "ipAddress": { "type": "string" }
              }
            },
            "mandator": {
              "type": "object",
              "required": ["organizationIdentifier"],
              "additionalProperties": true,
              "properties": {
                "id":                     { "type": "string" },
                "commonName":             { "type": "string" },
                "country":                { "type": "string" },
                "email":                  { "type": "string" },
                "organization":           { "type": "string" },
                "organizationIdentifier": { "type": "string" },
                "serialNumber":           { "type": "string" }
              }
            },
            "power": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "action":   {},
                  "domain":   { "type": "string" },
                  "function": { "type": "string" },
                  "type":     { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "validFrom":      { "type": "string" },
    "validUntil":     { "type": "string" },
    "expirationDate": { "type": "string" },
    "issuanceDate":   { "type": "string" }
  }
}
