{
  "credential_configuration_id": "learcredential.employee.sd.1",
  "description": "Verifiable Credential for employees of an organization",
  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Employee",
        "locale": "en",
        "description": "Verifiable Credential for employees of an organization"
      },
      {
        "name": "Credencial LEAR Empleado",
        "locale": "es",
        "description": "Credencial Verificable para empleados de una organización"
      },
      {
        "name": "Credencial LEAR Empleat",
        "locale": "ca",
        "description": "Credencial Verificable per a empleats d'una organització"
      }
    ],
    "claims": [
      { "path": ["mandator", "commonName"],             "display": [{ "name": "Common Name", "locale": "en" }, { "name": "Nombre Común", "locale": "es" }, { "name": "Nom Comú", "locale": "ca" }] },
      { "path": ["mandator", "country"],                "display": [{ "name": "Country", "locale": "en" }, { "name": "País", "locale": "es" }, { "name": "País", "locale": "ca" }] },
      { "path": ["mandator", "email"],                  "display": [{ "name": "Email", "locale": "en" }, { "name": "Correo Electrónico", "locale": "es" }, { "name": "Correu Electrònic", "locale": "ca" }] },
      { "path": ["mandator", "organization"],           "display": [{ "name": "Organization", "locale": "en" }, { "name": "Organización", "locale": "es" }, { "name": "Organització", "locale": "ca" }] },
      { "path": ["mandator", "organizationIdentifier"], "display": [{ "name": "Organization ID", "locale": "en" }, { "name": "ID de Organización", "locale": "es" }, { "name": "ID d'Organització", "locale": "ca" }] },
      { "path": ["mandator", "serialNumber"],           "display": [{ "name": "Serial Number", "locale": "en" }, { "name": "Número de Serie", "locale": "es" }, { "name": "Número de Sèrie", "locale": "ca" }] },
      { "path": ["mandatee", "employeeId"],             "display": [{ "name": "Employee ID", "locale": "en" }, { "name": "ID de Empleado", "locale": "es" }, { "name": "ID d'Empleat", "locale": "ca" }] },
      { "path": ["mandatee", "email"],                  "display": [{ "name": "Email", "locale": "en" }, { "name": "Correo Electrónico", "locale": "es" }, { "name": "Correu Electrònic", "locale": "ca" }] },
      { "path": ["mandatee", "firstName"],              "display": [{ "name": "First Name", "locale": "en" }, { "name": "Nombre", "locale": "es" }, { "name": "Nom", "locale": "ca" }] },
      { "path": ["mandatee", "lastName"],               "display": [{ "name": "Last Name", "locale": "en" }, { "name": "Apellido", "locale": "es" }, { "name": "Cognom", "locale": "ca" }] },
      { "path": ["power"],                              "display": [{ "name": "Powers", "locale": "en" }, { "name": "Poderes", "locale": "es" }, { "name": "Poders", "locale": "ca" }] }
    ],
    "summary_claims": [
      ["mandatee", "firstName"],
      ["mandatee", "lastName"],
      ["mandatee", "email"]
    ]
  },
  "subject_extraction": {
    "strategy": "concat",
    "fields": ["mandatee.firstName", "mandatee.lastName"],
    "separator": " "
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandator.organizationIdentifier"
  },
  "policy_extraction": {
    "powers_path": "power",
    "mandator_path": "mandator",
    "org_id_field": "organizationIdentifier"
  },
  "token_claims_mapping": {
    "subject_paths": ["mandatee.email"],
    "id_token": {
      "given_name": "mandatee.firstName",
      "family_name": "mandatee.lastName",
      "email": "mandatee.email",
      "name": {
        "strategy": "concat",
        "paths": ["mandatee.firstName", "mandatee.lastName"],
        "separator": " "
      },
      "email_verified": { "strategy": "constant", "value": true }
    },
    "access_token": {},
    "id_token_embed": {
      "mandatee": "mandatee",
      "mandator": "mandator",
      "power": "power"
    },
    "access_token_embed": {
      "mandatee": "mandatee",
      "mandator": "mandator",
      "power": "power"
    },
    "scope": "openid learcredential"
  }
}
