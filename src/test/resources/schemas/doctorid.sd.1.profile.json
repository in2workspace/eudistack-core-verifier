{
  "credential_configuration_id": "doctorid.sd.1",
  "description": "Verifiable Credential for licensed medical doctors",
  "credential_metadata": {
    "display": [
      {
        "name": "Doctor ID",
        "locale": "en",
        "description": "Verifiable Credential for licensed medical doctors"
      },
      {
        "name": "Identificación Médica",
        "locale": "es",
        "description": "Credencial Verificable para médicos colegiados"
      }
    ],
    "claims": [
      { "path": ["firstName"],          "display": [{ "name": "First Name", "locale": "en" }, { "name": "Nombre", "locale": "es" }] },
      { "path": ["lastName"],           "display": [{ "name": "Last Name", "locale": "en" }, { "name": "Apellidos", "locale": "es" }] },
      { "path": ["registrationNumber"], "display": [{ "name": "Registration Number", "locale": "en" }, { "name": "Número de Colegiado", "locale": "es" }] },
      { "path": ["nationalId"],         "display": [{ "name": "National ID", "locale": "en" }, { "name": "DNI", "locale": "es" }] },
      { "path": ["provincialBoard"],    "display": [{ "name": "Provincial Board", "locale": "en" }, { "name": "Colegio Provincial", "locale": "es" }] },
      { "path": ["specialty"],          "display": [{ "name": "Specialty", "locale": "en" }, { "name": "Especialidad", "locale": "es" }] },
      { "path": ["email"],              "display": [{ "name": "Email", "locale": "en" }, { "name": "Correo Electrónico", "locale": "es" }] },
      { "path": ["country"],            "display": [{ "name": "Country", "locale": "en" }, { "name": "País", "locale": "es" }] }
    ],
    "summary_claims": [
      ["firstName"],
      ["lastName"],
      ["email"]
    ]
  },
  "subject_extraction": {
    "strategy": "concat",
    "fields": ["firstName", "lastName"],
    "separator": " "
  },
  "token_claims_mapping": {
    "subject_paths": ["email"],
    "id_token": {
      "given_name": "firstName",
      "family_name": "lastName",
      "email": "email",
      "name": {
        "strategy": "concat",
        "paths": ["firstName", "lastName"],
        "separator": " "
      },
      "email_verified": { "strategy": "constant", "value": true }
    },
    "access_token": {},
    "id_token_embed": {
      "firstName": "firstName",
      "lastName": "lastName",
      "registrationNumber": "registrationNumber",
      "nationalId": "nationalId",
      "provincialBoard": "provincialBoard",
      "specialty": "specialty",
      "email": "email",
      "country": "country"
    },
    "access_token_embed": {
      "registrationNumber": "registrationNumber",
      "specialty": "specialty",
      "email": "email"
    },
    "scope": "openid doctorid"
  }
}