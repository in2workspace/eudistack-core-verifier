{
  "credential_configuration_id": "learcredential.machine.sd.1",
  "description": "Verifiable Credential for machines",
  "credential_metadata": {
    "display": [
      {
        "name": "LEAR Credential Machine",
        "locale": "en",
        "description": "Verifiable Credential for machines"
      },
      {
        "name": "Credencial LEAR Máquina",
        "locale": "es",
        "description": "Credencial Verificable para máquinas"
      },
      {
        "name": "Credencial LEAR Màquina",
        "locale": "ca",
        "description": "Credencial Verificable per a màquines"
      }
    ],
    "claims": [
      { "path": ["mandator", "commonName"],             "display": [{ "name": "Common Name", "locale": "en" }, { "name": "Nombre Común", "locale": "es" }, { "name": "Nom Comú", "locale": "ca" }] },
      { "path": ["mandator", "country"],                "display": [{ "name": "Country", "locale": "en" }, { "name": "País", "locale": "es" }, { "name": "País", "locale": "ca" }] },
      { "path": ["mandator", "email"],                  "display": [{ "name": "Email", "locale": "en" }, { "name": "Correo Electrónico", "locale": "es" }, { "name": "Correu Electrònic", "locale": "ca" }] },
      { "path": ["mandator", "organization"],           "display": [{ "name": "Organization", "locale": "en" }, { "name": "Organización", "locale": "es" }, { "name": "Organització", "locale": "ca" }] },
      { "path": ["mandator", "organizationIdentifier"], "display": [{ "name": "Organization ID", "locale": "en" }, { "name": "ID de Organización", "locale": "es" }, { "name": "ID d'Organització", "locale": "ca" }] },
      { "path": ["mandator", "serialNumber"],           "display": [{ "name": "Serial Number", "locale": "en" }, { "name": "Número de Serie", "locale": "es" }, { "name": "Número de Sèrie", "locale": "ca" }] },
      { "path": ["mandatee", "serviceId"],              "display": [{ "name": "Service ID", "locale": "en" }, { "name": "ID de Servicio", "locale": "es" }, { "name": "ID de Servei", "locale": "ca" }] },
      { "path": ["mandatee", "domain"],                 "display": [{ "name": "Domain", "locale": "en" }, { "name": "Dominio", "locale": "es" }, { "name": "Domini", "locale": "ca" }] },
      { "path": ["mandatee", "ipAddress"],              "display": [{ "name": "IP Address", "locale": "en" }, { "name": "Dirección IP", "locale": "es" }, { "name": "Adreça IP", "locale": "ca" }] },
      { "path": ["power"],                              "display": [{ "name": "Powers", "locale": "en" }, { "name": "Poderes", "locale": "es" }, { "name": "Poders", "locale": "ca" }] }
    ],
    "summary_claims": [
      ["mandatee", "serviceId"],
      ["mandatee", "domain"],
      ["mandatee", "ipAddress"]
    ]
  },
  "subject_extraction": {
    "strategy": "field",
    "fields": ["mandatee.domain"],
    "separator": null
  },
  "organization_extraction": {
    "strategy": "field",
    "field": "mandator.organizationIdentifier"
  },
  "policy_extraction": {
    "powers_path": "power",
    "mandator_path": "mandator",
    "org_id_field": "organizationIdentifier"
  },
  "token_claims_mapping": {
    "subject_paths": ["mandatee.ipAddress", "mandatee.domain"],
    "access_token": {},
    "id_token_embed": {
      "mandatee": "mandatee",
      "mandator": "mandator",
      "power": "power"
    },
    "access_token_embed": {
      "mandatee": "mandatee",
      "mandator": "mandator",
      "power": "power"
    },
    "scope": "machine learcredential"
  }
}
